      "check_type": "rule",
      "weight": 1,
      "rule": {
        "required_fields_any": [
          "meta.topic",
          "meta.lesson_type",
          "meta.class_grade",
          "meta.teacher"
        ],
        "min_present": 2
      },
      "hints": [
        "Укажите тему и тип урока (это помогает проверке структуры)."
      ]
    },
    {
      "criterion_id": "DIDACTIC_TASK_ALIGNMENT",
      "group": "DIDACTIC_TASK",
