{
  "version": "noo_v1",
  "level": "NOO",
  "title": "Анализ конспекта урока по ФГОС НОО (MVP)",
  "scoring": {
    "scale": [
      0,
      1,
      2
    ],
    "meaning": {
      "0": "не обнаружено в тексте / не подтверждено",
      "1": "частично / низкая уверенность / без явного подтверждения",
      "2": "обнаружено и подтверждено доказательствами"
    },
    "confidence_thresholds": {
      "low": 0.55,
      "high": 0.78
    }
  },
  "criteria": [
    {
      "criterion_id": "META_CORE",
      "group": "META",
      "title": "Паспорт урока (минимум)",
