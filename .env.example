# Telegram bot
BOT_TOKEN=__PUT_YOUR_TOKEN_HERE__
API_URL=http://api:8000

# Database
POSTGRES_DB=fgos
POSTGRES_USER=fgos
POSTGRES_PASSWORD=fgos
DATABASE_URL=postgresql+psycopg2://fgos:fgos@postgres:5432/fgos

# Redis / Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Storage
STORAGE_DIR=/data

# Service-auth (bot <-> api)
SERVICE_SECRET=__PUT_SECRET_HERE__

MAX_UPLOAD_MB=25
BOT_DNS1=1.1.1.1
BOT_DNS2=8.8.8.8
